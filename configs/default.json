{
  "seed": 42,
  "deterministic": true,

  "dataset": {
    "output_path": "artifacts/datasets/point_mass_dataset.npz",
    "num_episodes": 100,
    "steps_per_episode": 50,
    "dt": 0.1,
    "damping": 0.08,
    "max_position": 10.0,
    "max_velocity": 5.0,
    "max_acceleration": 1.0,
    "process_noise_std": 0.01
  },

  "split": {
    "val_ratio": 0.2
  },

  "model": {
    "state_dim": 4,
    "action_dim": 2,
    "hidden_dims": [128, 128, 64],
    "dropout": 0.0,
    "predict_delta": false
  },

  "training": {
    "run_name": "default_run",
    "batch_size": 256,
    "epochs": 40,
    "learning_rate": 0.001,
    "weight_decay": 0.00001,
    "log_every": 20,
    "checkpoint_dir": "artifacts/runs/default_run/checkpoints",
    "artifacts_dir": "artifacts/runs/default_run",
    "num_workers": 0
  },

  "evaluation": {
    "output_dir": "artifacts/eval/default_run",
    "num_rollout_steps": 60,
    "num_rollouts": 5
  }
}